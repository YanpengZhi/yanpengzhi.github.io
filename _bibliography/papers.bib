      year={2025-5-12},
      abbr={Talk},
      selected={false},
}

@misc{Gandalf,
      title={Gradient Flows on Wasserstein Spaces},
      author={},
      abstract={This talk serves as a gentle introduction to gradient flows on Wasserstein spaces. We will recall the definition of Wasserstein distances as optimal cost of transportation. And the transporting dynamics, or say the Benamou-Brenier formula, give rise to ''Riemannian structures'' on Wasserstein spaces. Then we can define their tangent spaces and formulate gradient flows on them. There are also some equivalent objects from PDE and stochastic analysis, corresponding to Wasserstein gradient flows. For example, choosing the entropy functional, the gradient flow turns out to be the heat equation, and gives the distribution of a Brownian motion. The contraction rate of this entropy gradient flow can be related to the curvature lower bound of the base space. Other examples and some generalization will be discussed.},
      journal={Gandalf Talk, Durham University, Durham, U.K.},
      year={2024-11-20},
      abbr={Talk},
      selected={false},
}





